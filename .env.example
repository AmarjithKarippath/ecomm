# Backend
DATABASE_URL=postgresql+psycopg://ecomm:ecomm@db:5432/ecomm
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-in-prod
JWT_ALG=HS256
JWT_EXPIRE_MIN=10080
CORS_ORIGINS=http://localhost:5173

# Media storage. Leave S3_BUCKET empty to use local disk.
S3_BUCKET=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MEDIA_LOCAL_DIR=/app/media
PUBLIC_MEDIA_BASE=http://localhost:8000/media

# Frontend (Vite picks these up at build/dev time)
VITE_API_BASE=http://localhost:8000

# Landing (Next.js)
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:5173/login
